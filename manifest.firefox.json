{
  "manifest_version": 3,
  "name": "Personal Agent",
  "version": "2026.6.0",
  "default_locale": "en",
  "description": "__MSG_extDescription__",
  "browser_specific_settings": {
    "gecko": {
      "id": "personal-agent-browser@luebke.dev",
      "strict_min_version": "128.0"
    }
  },
  "permissions": ["tabs", "scripting", "storage", "alarms", "identity", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": { "scripts": ["background.js"], "type": "module" },
  "icons": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Personal Agent",
    "default_icon": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
  }
}
