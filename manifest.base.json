{
  "manifest_version": 3,
  "name": "Personal Agent",
  "default_locale": "en",
  "description": "__MSG_extDescription__",
  "homepage_url": "https://github.com/personal-agent-org/browser-extension",
  "permissions": ["tabs", "scripting", "storage", "alarms", "identity", "tabCapture", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "icons": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Personal Agent",
    "default_icon": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "meeting/registry.js",
        "meeting/jitsi.js",
        "meeting/bbb.js",
        "meeting/opentalk.js",
        "content-meeting.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    { "resources": ["meeting/jitsi-inject.js"], "matches": ["<all_urls>"] }
  ]
}
